{
  "name":"mydevcontainer",
  "build": {
    "dockerfile": "dockerfile"
  },
  "runArgs": ["--network=develop"],
  "features":{
    "ghcr.io/rocker-org/devcontainer-features/apt-packages:1": {
      // Jetbrains Rider requires the JRE and SSH for remote development
      "packages": "openssh-server,openjdk-25-jre"
    }
  },
  "postCreateCommand": "curl -fsSL https://opencode.ai/install | bash",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "redhat.vscode-xml"
      ]
    }
  }
}
